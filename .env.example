# Copy this file to .env (already gitignored) and fill in your key(s).
# eval_system/judges/factory.py loads .env automatically -- no need to
# export these in your shell every session.

# Which judge provider the judge metrics (faithfulness,
# instruction_adherence_judge, emotional_appropriateness) use by default.
# One of: anthropic | openai
VOXGATE_JUDGE_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=
# Optional model override (default: gpt-4o)
# OPENAI_JUDGE_MODEL=gpt-4o

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Gemini (emotion_appropriateness_mm.py -- multimodal emotion judge) ---
# Loaded directly by that metric, independent of VOXGATE_JUDGE_PROVIDER above.
GEMINI_API_KEY=
